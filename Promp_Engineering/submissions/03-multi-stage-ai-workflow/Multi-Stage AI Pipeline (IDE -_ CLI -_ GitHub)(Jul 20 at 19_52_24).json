              "requiredField": true
            },
            {
              "fieldLabel": "Target Runtime",
              "fieldName": "Target Runtime",
              "fieldType": "text",
              "placeholder": "e.g. Bash, Node.js, Python",
              "requiredField": true
            },
            {
              "fieldLabel": "Existing Code",
              "fieldName": "Existing Code",
              "fieldType": "textarea",
              "placeholder": "Paste any existing code or context (optional)",
              "requiredField": false
            }
          ]
        }
      },
      "webhookId": "f454a7e0-99f3-4191-b616-b5db54bdc273"
    },
    {
      "id": "83af4e4e-5954-4abc-99bd-00530576bcc3",
      "name": "Stage 1 - IDE Analyzer",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        224,
        112
      ],
      "parameters": {
        "promptType": "define",
        "hasOutputParser": true,
        "text": "=You are an IDE-based coding assistant. Analyse the task below BEFORE any code is written and produce a structured integration plan.\n\nTask: {{ $json['Task Description'] }}\nTarget runtime / CLI environment: {{ $json['Target Runtime'] }}\nExisting code / context:\n{{ $json['Existing Code'] || 'none provided' }}\n\nBreak the work into clear components and ordered implementation steps."
      }
    },
