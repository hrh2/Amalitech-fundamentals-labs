        336
      ],
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-5-mini"
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "GKzdBVz33QnRcAuG",
          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "id": "f872039e-ff78-47ec-8ea5-29c1cb0684b8",
      "name": "Files Schema",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        720,
        336
      ],
      "parameters": {
        "schemaType": "fromJson",
        "jsonSchemaExample": "{\"commit_message\":\"Add generated CLI scripts\",\"files\":[{\"path\":\"scripts/example.sh\",\"content\":\"#!/usr/bin/env bash\\necho hello\",\"description\":\"what this file does\"}]}"
      }
    },
    {
      "id": "a702af4e-dc3a-4865-b1d9-9a64cb8f0c99",
      "name": "Split Files",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        928,
        112
      ],
      "parameters": {
        "jsCode": "const data = ($input.first().json.output) || {};\nconst files = Array.isArray(data.files) ? data.files : [];\nconst commitMessage = data.commit_message || 'Add generated CLI scripts';\nif (files.length === 0) { return []; }\nreturn files.map(f => ({ json: {\n  path: f.path,\n  content: f.content,\n  description: f.description || \"\",\n  commit_message: commitMessage,\n} }));"
      }
    },
    {
