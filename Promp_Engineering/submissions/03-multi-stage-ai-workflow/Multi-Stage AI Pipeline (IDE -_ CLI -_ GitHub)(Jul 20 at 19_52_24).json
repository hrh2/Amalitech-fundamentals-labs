      }
    },
    {
      "id": "233765c7-4b5d-4784-b869-b1c4053fcddb",
      "name": "Stage 2 - CLI Generator",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        576,
        112
      ],
      "parameters": {
        "promptType": "define",
        "hasOutputParser": true,
        "text": "=You are a CLI-focused code generator. Using the integration plan below, produce complete, runnable script files ready to commit to a repository.\n\nIntegration plan (JSON):\n{{ JSON.stringify($json.output) }}\n\nReturn one entry per file with a repo-relative path and full file content. Include a concise git commit message."
      }
    },
    {
      "id": "3c2a9c70-a5ed-4856-8be4-f06abd693fee",
      "name": "Generator Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
